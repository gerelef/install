if [[ -n "$INSTALL_VIRTUALIZATION" ]]; then
    _echo status "-------------------INSTALLING VIRTUALIZATION PACKAGES----------------"
    sudo dnf install -y --quiet --best --allowerasing --skip-unavailable $INSTALLABLE_VIRTUALIZATION_PACKAGES
