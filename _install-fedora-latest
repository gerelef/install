    flatpak install flathub --system --noninteractive -y $INSTALLABLE_GNOME_FLATPAKS
fi

# this needs to be up-to-date for some commands
_echo debug "running updatedb..."
if [[ $(sudo updatedb 2> /dev/null) ]]; then
